{
  "archiveRoots": [
    "/Users/katops/git/test_pics"
  ],
  "outputPath": "./outputs/test-pics",
  "privacyMode": "local-first",
  "ocrLanguages": [
    "eng"
  ],
  "exclusions": {
    "pathGlobs": [
      "**/.git/**",
      "**/node_modules/**",
      "**/.cache/**",
      "**/outputs/**",
      "**/System Volume Information/**",
      "**/$RECYCLE.BIN/**",
      "**/.Trash/**"
    ],
    "extensions": [
      ".tmp",
      ".part",
      ".crdownload"
    ]
  },
  "inventory": {
    "hashAlgorithm": "SHA256",
    "hashMaxBytes": 0,
    "progressEvery": 250
  },
  "dedupe": {
    "enableNearDuplicate": false,
    "similarityThreshold": 0.8,
    "czkawka": {
      "command": "czkawka_cli",
      "arguments": [
        "image",
        "--dirs",
        "{directories}",
        "--min-size",
        "0",
        "--similarity",
        "{similarityThreshold}"
      ]
    },
    "perceptualHash": {
      "command": "identify",
      "arguments": [
        "-quiet",
        "-format",
        "%#",
        "{path}"
      ]
    }
  },
  "metadata": {
    "enableExifTool": false,
    "enableMediaProbe": true,
    "exifToolJson": {
      "command": "exiftool",
      "arguments": [
        "-j",
        "-time:all",
        "-s",
        "{path}"
      ]
    },
    "ffprobe": {
      "command": "ffprobe",
      "arguments": [
        "-v",
        "quiet",
        "-print_format",
        "json",
        "-show_streams",
        "-show_format",
        "{path}"
      ]
    }
  },
  "extraction": {
    "maxInlineTextBytes": 5242880,
    "enableExternalConverters": false,
    "converters": {
      "markitdown": {
        "command": "markitdown",
        "arguments": [
          "{path}"
        ]
      },
      "docling": {
        "command": "docling",
        "arguments": [
          "{path}"
        ]
      },
      "tesseract": {
        "command": "tesseract",
        "arguments": [
          "{path}",
          "stdout",
          "-l",
          "{ocrLanguages}"
        ]
      }
    }
  },
  "transcription": {
    "enabled": false,
    "engine": "whisper",
    "commandTemplate": {
      "command": "whisper",
      "arguments": [
        "{path}",
        "--model",
        "base",
        "--output_format",
        "txt"
      ]
    }
  },
  "classification": {
    "enabled": false,
    "provider": "ollama",
    "model": "qwen3:4b",
    "maxChars": 6000,
    "endpoint": "http://localhost:11434",
    "systemPrompt": "You are an archive analyst. Categorize file content into themes and extract keywords."
  },
  "knowledgeBase": {
    "vaultName": "archive-vault",
    "copyOriginals": false
  },
  "entities": {
    "enabled": false,
    "model": "fastino/gliner2-base-v1",
    "labels": ["person", "brand", "organization", "location", "topic", "concept", "product", "event"],
    "threshold": 0.5,
    "maxChars": 10000
  },
  "search": {
    "enabled": false,
    "embeddingModel": "all-MiniLM-L6-v2",
    "chromaPersistDir": "./outputs/chroma_db",
    "topK": 10
  },
  "cleanup": {
    "enabled": false,
    "targets": ["extracted", "transcripts", "sidecars"]
  },
  "actions": {
    "enableApplyReviewedActions": false,
    "quarantinePath": "./outputs/quarantine"
  },
  "safety": {
    "allowOutputInsideRoot": false,
    "allowDelete": false,
    "requireApprovedManifest": true
  }
}
